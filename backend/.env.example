# Lisan Backend — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env.
# See /docs/env-vars.md for full documentation.

# ── Required ────────────────────────────────────────────────────────────────

# PostgreSQL connection string (Supabase)
DATABASE_URL=postgresql://postgres:your-password@db.xxxx.supabase.co:5432/postgres

# Clerk Frontend API URL (from Clerk Dashboard → API Keys → Advanced)
# Note: this is CLERK_AUTHORITY (the JWKS issuer URL), not CLERK_SECRET_KEY
CLERK_AUTHORITY=https://xxxx.clerk.accounts.dev

# OpenAI API key for AI conversation pipeline
OPENAI_API_KEY=sk-your-openai-api-key

# Google Cloud TTS API key for Persian speech synthesis
GOOGLE_TTS_API_KEY=your-google-tts-api-key

# Privacy policy version stored on parental consent records (PIPEDA compliance)
PRIVACY_POLICY_VERSION=v1.0

# ── Optional ─────────────────────────────────────────────────────────────────

# Sentry DSN for backend error tracking (leave empty to disable)
SENTRY_DSN_BACKEND=

# PostHog API key for product analytics (leave empty to disable)
POSTHOG_API_KEY=

# Transcript retention period in days (default: 90)
TRANSCRIPT_RETENTION_DAYS=90

# Application version string for structured logging
APP_VERSION=

# AI persona system prompts (placeholders — not yet consumed by the pipeline)
SYSTEM_PROMPT_KIAN=
SYSTEM_PROMPT_NIKA=
SYSTEM_PROMPT_YARA=

# Google TTS voice IDs per persona (placeholders — blocked on voice selection)
TTS_VOICE_KIAN=
TTS_VOICE_NIKA=
TTS_VOICE_YARA=
