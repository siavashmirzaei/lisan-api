# Lisan Mobile — Environment Variables (Expo)
# Copy this file to .env and fill in real values. Never commit .env.
# See /docs/env-vars.md for full documentation.
# All EXPO_PUBLIC_* variables are bundled into the app at build time.

# ── Required ────────────────────────────────────────────────────────────────

# Clerk publishable key for mobile authentication (from Clerk Dashboard → API Keys)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-publishable-key

# Backend API base URL
EXPO_PUBLIC_API_BASE_URL=http://localhost:5000

# ── Optional ─────────────────────────────────────────────────────────────────

# Sentry DSN for mobile error tracking (leave empty to disable)
EXPO_PUBLIC_SENTRY_DSN=

# PostHog API key for mobile product analytics (leave empty to disable)
EXPO_PUBLIC_POSTHOG_KEY=
